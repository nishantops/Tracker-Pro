# =============================================================================
# UPSC Tracker — Environment Configuration Template
# Copy this file to .env and fill in real values.
# .env is gitignored; this file is safe to commit.
# =============================================================================

# ── App Identity ──────────────────────────────────────────────────────────────
VITE_APP_NAME=UPSC Command Centre
VITE_APP_VERSION=3.0.0
VITE_APP_TAGLINE=UPSC CSE 2027
VITE_DEVELOPER_NAME=SAN Labs
VITE_HEADER_AVATAR=SAN

# ── Supabase ──────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → project → Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# ── Admin / Auth ──────────────────────────────────────────────────────────────
VITE_ADMIN_EMAIL=admin@yourdomain.com
VITE_SUPERUSER_EMAIL=superuser@yourdomain.com
VITE_SUPERUSER_ALIAS=superuser

# ── Session ───────────────────────────────────────────────────────────────────
# Auto-logout after N milliseconds of inactivity (900000 = 15 min)
VITE_AUTO_LOGOUT_MS=900000
# How often to run the idle/focus check in the background (120000 = 2 min)
VITE_SESSION_CHECK_INTERVAL_MS=120000

# ── Messaging ─────────────────────────────────────────────────────────────────
VITE_DEFAULT_DAILY_MSG_LIMIT=3
VITE_WEEKLY_FEEDBACK_DAYS=7
# How often to poll for unread messages (ms)
VITE_MSG_UNREAD_POLL_MS=120000

# ── Plan Table (spreadsheet) ──────────────────────────────────────────────────
VITE_PT_DEBOUNCE_MS=500
VITE_PT_MAX_ZOOM=2.0
VITE_PT_MIN_ZOOM=0.4

# ── Gantt ─────────────────────────────────────────────────────────────────────
# 0 = unlimited; set e.g. 104 for a 2-year cap
VITE_GANTT_MAX_UNITS=0

# ── Metrics ───────────────────────────────────────────────────────────────────
VITE_METRICS_FLUSH_MS=10000

# ── AI (Gemini) ───────────────────────────────────────────────────────────────
# Get API key from: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=YOUR_GEMINI_API_KEY
VITE_GEMINI_MODEL=gemini-2.5-flash
VITE_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/models
VITE_AI_HISTORY_LIMIT=50
VITE_AI_CONTEXT_WINDOW=10
VITE_AI_MAX_OUTPUT_TOKENS=800
VITE_AI_TEMPERATURE=0.7

# ── Plan Grid ─────────────────────────────────────────────────────────────────
VITE_PLAN_GRID_COLS=12
VITE_PLAN_CARD_DEFAULT_W=4
VITE_PLAN_CARD_DEFAULT_H=2
VITE_PLAN_CARD_MIN_W=3
VITE_PLAN_CARD_MIN_H=2
VITE_PLAN_ROW_HEIGHT=68
VITE_PLAN_GRID_MARGIN=12
VITE_PLAN_LAYOUT_DEBOUNCE_MS=600
VITE_PLAN_LAYOUT_DB_TABLE=upsc_plan_layouts
VITE_PLAN_LAYOUT_LS_KEY=plan-grid-layouts-v1

# ── Pie Matrix Grid ────────────────────────────────────────────────────────────
VITE_PIE_GRID_COLS=5
VITE_PIE_ROW_HEIGHT=90
VITE_PIE_GRID_MARGIN=12
VITE_PIE_LAYOUT_DB_TABLE=upsc_pie_card_layouts
VITE_PIE_LAYOUT_LS_KEY=pie-matrix-layouts-v3

# ── Cache TTLs ────────────────────────────────────────────────────────────────
VITE_TRACKER_CACHE_TTL_MS=60000
VITE_PLANS_CACHE_TTL_MS=30000

# ── Exam Dates ────────────────────────────────────────────────────────────────
VITE_PRELIMS_DATE=May 23, 2027 09:00:00
VITE_MAINS_DATE=August 20, 2027 09:00:00
